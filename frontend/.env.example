# Frontend (Next.js)
# Required for Supabase auth + data
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: override disruptions websocket endpoint
# If omitted, app falls back to ws://localhost:8000/ws/disruptions
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws/disruptions
