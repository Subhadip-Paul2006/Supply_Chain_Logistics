# ─── Database ────────────────────────────────────────────────────────────────
# asyncpg driver required — note postgresql+asyncpg:// prefix
DATABASE_URL=postgresql+asyncpg://r3flex:r3flex_secret@localhost:5432/r3flex

POSTGRES_USER=r3flex
POSTGRES_PASSWORD=r3flex_secret
POSTGRES_DB=r3flex

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── LLM — Google Gemini (FREE tier) ─────────────────────────────────────────
# Get key at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-google-api-key-here
GEMINI_MODEL=gemini-2.0-flash

# ─── Signal Feeds (OPTIONAL — mock fallbacks activate if missing) ─────────────
# NewsAPI: https://newsapi.org/register (free tier = 100 req/day)
NEWS_API_KEY=299a2b46e42c4c4497a5b81973e03d35

# NOAA Climate Data: https://www.ncdc.noaa.gov/cdo-web/token
NOAA_API_KEY=RMnxWnzIScTqUOAlyJKsMaUdlicrDqYV

# ─── Business Rules ───────────────────────────────────────────────────────────
# Confidence threshold — above this = auto-execute, below = human approval
CONFIDENCE_THRESHOLD=0.85

# Demo company ID used for WebSocket channel: disruptions:{COMPANY_ID}
COMPANY_ID=pharma-distrib-india

# Scheduler interval in seconds
POLL_INTERVAL_SECONDS=60

# Max tokens per LLM call
LLM_MAX_TOKENS=1000

# ─── App ──────────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
